{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolicyRecord",
  "type": "object",
  "required": [
    "policy_id",
    "scope",
    "project_id",
    "key",
    "value",
    "status",
    "approved_at",
    "source_commit_id"
  ],
  "properties": {
    "policy_id": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "string",
      "enum": ["global", "project"]
    },
    "project_id": { "type": ["string", "null"] },
    "key": { "type": "string", "minLength": 1 },
    "value": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["approved"]
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_commit_id": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
