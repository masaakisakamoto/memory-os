{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "continuity-check-cli-output.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "input", "result", "error"],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "input_format",
        "project_id",
        "session_id",
        "draft_id"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["text", "stdin", "input_file"]
        },
        "input_format": {
          "type": "string",
          "enum": ["raw_text", "prompt_draft_json"]
        },
        "project_id": {
          "type": ["string", "null"]
        },
        "session_id": {
          "type": "string"
        },
        "draft_id": {
          "type": "string"
        }
      }
    },
    "result": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "claims",
            "issues",
            "selectedBlocks",
            "decision",
            "promptGuardResult",
            "ledgerEvents"
          ],
          "properties": {
            "claims": {
              "type": "array"
            },
            "issues": {
              "type": "array"
            },
            "selectedBlocks": {
              "type": "array"
            },
            "decision": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "decision_id",
                "severity",
                "action",
                "selectedInjectionBlocks",
                "explanationTrace",
                "created_at"
              ],
              "properties": {
                "decision_id": { "type": "string" },
                "severity": {
                  "type": "string",
                  "enum": ["warn", "error", "block"]
                },
                "action": { "type": "string" },
                "selectedInjectionBlocks": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "explanationTrace": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["trace_id", "decision_id", "entries"],
                  "properties": {
                    "trace_id": { "type": "string" },
                    "decision_id": { "type": "string" },
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "step",
                          "stage",
                          "rule_id",
                          "status",
                          "summary",
                          "related_ids"
                        ],
                        "properties": {
                          "step": { "type": "number" },
                          "stage": { "type": "string" },
                          "rule_id": { "type": "string" },
                          "status": { "type": "string" },
                          "summary": { "type": "string" },
                          "related_ids": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        },
                        "additionalProperties": false
                      }
                    }
                  }
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            },
            "promptGuardResult": {
              "$ref": "./prompt-guard-result.schema.json"
            },
            "ledgerEvents": {
              "type": "array"
            }
          }
        }
      ]
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "INPUT_SOURCE_CONFLICT",
                "INPUT_SOURCE_MISSING",
                "INPUT_FILE_READ_FAILED",
                "INPUT_FORMAT_INVALID",
                "PROMPT_DRAFT_INVALID",
                "EMPTY_INPUT"
              ]
            },
            "message": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "ok": { "const": true } }
      },
      "then": {
        "properties": {
          "result": { "not": { "type": "null" } },
          "error": { "type": "null" }
        }
      }
    },
    {
      "if": {
        "properties": { "ok": { "const": false } }
      },
      "then": {
        "properties": {
          "result": { "type": "null" },
          "error": { "not": { "type": "null" } }
        }
      }
    }
  ]
}
