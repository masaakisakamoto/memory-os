{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContinuityIssue",
  "type": "object",
  "required": [
    "issue_id",
    "issue_type",
    "severity",
    "message",
    "evidence",
    "blocking",
    "repairable"
  ],
  "properties": {
    "issue_id": { "type": "string", "minLength": 1 },
    "issue_type": {
      "type": "string",
      "enum": [
        "ambiguous_reference",
        "state_mismatch_confirmed",
        "policy_violation"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["warn", "error", "block"]
    },
    "message": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_type", "source_id", "field", "value"],
        "properties": {
          "source_type": {
            "type": "string",
            "enum": ["draft", "approved_state", "policy", "decision"]
          },
          "source_id": { "type": "string", "minLength": 1 },
          "field": { "type": ["string", "null"] },
          "value": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "blocking": { "type": "boolean" },
    "repairable": { "type": "boolean" }
  },
  "additionalProperties": false
}
