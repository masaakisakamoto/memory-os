{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecisionResult",
  "type": "object",
  "required": [
    "decision_id",
    "severity",
    "action",
    "selectedInjectionBlocks",
    "explanationTrace",
    "created_at"
  ],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "severity": {
      "type": "string",
      "enum": ["none", "warn", "error", "block"]
    },
    "action": {
      "type": "string",
      "enum": [
        "allow_no_injection",
        "allow_with_silent_injection",
        "allow_with_visible_suggestion",
        "block_due_to_policy"
      ]
    },
    "selectedInjectionBlocks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "explanationTrace": {
      "type": "object",
      "required": ["trace_id", "decision_id", "entries"],
      "properties": {
        "trace_id": { "type": "string", "minLength": 1 },
        "decision_id": { "type": "string", "minLength": 1 },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "step",
              "stage",
              "rule_id",
              "status",
              "summary",
              "related_ids"
            ],
            "properties": {
              "step": {
                "type": "integer",
                "minimum": 1
              },
              "stage": {
                "type": "string",
                "enum": ["normalize", "extract", "detect", "inject", "decide"]
              },
              "rule_id": { "type": "string", "minLength": 1 },
              "status": {
                "type": "string",
                "enum": ["applied", "skipped"]
              },
              "summary": { "type": "string", "minLength": 1 },
              "related_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
